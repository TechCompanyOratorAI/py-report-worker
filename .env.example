# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-southeast-1
AWS_SQS_SEMANTIC_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/your-account/analysis-queue

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/oratorai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=oratorai
DB_USER=username
DB_PASSWORD=password

# Worker Configuration
WORKER_ID=semantic-worker-1
POLL_INTERVAL=5
MAX_MESSAGES=1
WAIT_TIME_SECONDS=20

# Webhook Configuration
WEBHOOK_BASE_URL=http://localhost:3000
WEBHOOK_SECRET=your_webhook_secret_here

# Semantic Analysis Configuration
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SIMILARITY_THRESHOLD=0.7
BATCH_SIZE=32

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=colored

# Temp files
TEMP_DIR=/tmp/semantic-worker
CLEANUP_TEMP_FILES=true